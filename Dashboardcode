<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blackburn Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #fafaf8;
  --surface: #fff;
  --border: #e4e0d8;
  --border-light: #eeeae3;
  --forest: #1e3d2f;
  --forest-mid: #2d5c46;
  --forest-light: #e8f0eb;
  --forest-lighter: #f0f6f2;
  --text: #1a1a18;
  --text-mid: #4a4a45;
  --text-muted: #6b6960;
  --text-faint: #a8a49c;
  --red: #c0392b;
  --red-bg: #fdf0ef;
  --amber: #b7621a;
  --amber-bg: #fdf6ee;
  --green: #1e6b3a;
  --green-bg: #edf5f0;
  --blue: #1a4f7a;
  --blue-bg: #eef4fa;
  --radius: 10px;
  --radius-lg: 14px;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding: 2rem 1.5rem 4rem;
  max-width: 1100px;
  margin: 0 auto;
}

/* ‚îÄ‚îÄ Header ‚îÄ‚îÄ */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2rem;
}
.header-left {
  display: flex;
  align-items: flex-end;
  gap: 1.5rem;
}
.brand h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 400;
  letter-spacing: 0.06em;
  color: var(--forest);
  line-height: 1;
  text-transform: uppercase;
}
.brand p {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.14em;
  color: var(--text-faint);
  text-transform: uppercase;
  margin-top: 5px;
}
.divider-v { width: 1px; height: 36px; background: var(--border); }
.date-block .day {
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  font-weight: 300;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}
.date-block .full-date {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--text-faint);
  margin-top: 3px;
}
.header-right {
  display: flex;
  align-items: center;
  gap: 8px;
}
.icon-btn {
  background: var(--surface);
  border: 0.5px solid var(--border);
  color: var(--text-muted);
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  padding: 6px 12px;
  border-radius: 20px;
  cursor: pointer;
  letter-spacing: 0.04em;
  transition: border-color 0.2s, color 0.2s;
}
.icon-btn:hover { border-color: var(--forest); color: var(--forest); }
.live-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--green);
  background: var(--green-bg);
  padding: 4px 10px;
  border-radius: 20px;
  border: 0.5px solid rgba(30,107,58,0.2);
}
.live-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--green);
  animation: pulse 2.5s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ‚îÄ‚îÄ Sections ‚îÄ‚îÄ */
.section { margin-bottom: 2.5rem; }
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 1rem;
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 400;
  color: var(--forest);
  letter-spacing: 0.04em;
}
.section-meta {
  display: flex;
  align-items: center;
  gap: 10px;
}
.section-ts {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
}
.section-count {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  background: var(--border-light);
  padding: 2px 8px;
  border-radius: 10px;
}

/* ‚îÄ‚îÄ Quick Stats ‚îÄ‚îÄ */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin-bottom: 2.5rem;
}
.stat-card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.375rem;
}
.stat-card.accent {
  background: var(--forest-lighter);
  border-color: rgba(30,61,47,0.12);
}
.stat-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 8px;
}
.stat-card.accent .stat-label { color: rgba(30,61,47,0.45); }
.stat-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 400;
  color: var(--text);
  line-height: 1;
}
.stat-card.accent .stat-value { color: var(--forest); }
.stat-sub {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  margin-top: 6px;
}
.stat-card.accent .stat-sub { color: rgba(30,61,47,0.45); }

/* ‚îÄ‚îÄ Cards ‚îÄ‚îÄ */
.card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.375rem 1.5rem;
}

/* ‚îÄ‚îÄ Email Grid ‚îÄ‚îÄ */
.email-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.email-card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.125rem 1.25rem;
  border-left: 3px solid var(--border);
  transition: border-color 0.2s;
}
.email-card:hover { border-color: #c8c2b6; border-left-color: inherit; }
.email-card.urgent { border-left-color: var(--red); }
.email-card.action { border-left-color: var(--amber); }
.email-card.fyi { border-left-color: var(--text-faint); }
.email-from {
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 2px;
}
.email-subject {
  font-size: 12px;
  color: var(--text-mid);
  margin-bottom: 8px;
}
.email-summary {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.5;
  margin-bottom: 8px;
}
.email-tags { display: flex; gap: 5px; flex-wrap: wrap; }
.tag {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  padding: 2px 7px;
  border-radius: 20px;
  border: 0.5px solid;
  letter-spacing: 0.02em;
}
.tag-urgent { color: var(--red); border-color: rgba(192,57,43,0.25); background: var(--red-bg); }
.tag-action { color: var(--amber); border-color: rgba(183,98,26,0.25); background: var(--amber-bg); }
.tag-fyi { color: var(--text-faint); border-color: var(--border); background: transparent; }
.tag-you { color: var(--blue); border-color: rgba(26,79,122,0.25); background: var(--blue-bg); }

.skeleton {
  background: linear-gradient(90deg, var(--border-light) 25%, #f5f2ec 50%, var(--border-light) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  height: 12px;
  margin-bottom: 4px;
}
.skeleton:last-child { width: 60%; }
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ‚îÄ‚îÄ Tasks ‚îÄ‚îÄ */
.task-list { display: flex; flex-direction: column; }
.task-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 0.5px solid var(--border-light);
}
.task-item:last-child { border-bottom: none; }
.priority-dot {
  width: 6px; height: 6px; border-radius: 50%;
  flex-shrink: 0; margin-top: 6px;
}
.p-4 { background: var(--red); }
.p-3 { background: var(--amber); }
.p-2 { background: #4a7fb5; }
.p-1 { background: var(--text-faint); }
.task-text { font-size: 13.5px; color: var(--text); line-height: 1.4; }
.task-meta {
  font-size: 11px;
  color: var(--text-faint);
  margin-top: 2px;
  font-family: 'DM Mono', monospace;
}
.task-meta.overdue { color: var(--red); }

/* ‚îÄ‚îÄ Rentals ‚îÄ‚îÄ */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
.metric-card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem 1.625rem;
  cursor: pointer;
  transition: border-color 0.2s;
}
.metric-card:hover { border-color: var(--forest); }
.metric-card.green-tint {
  background: var(--forest-lighter);
  border-color: rgba(30,61,47,0.12);
}
.metric-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 10px;
}
.metric-card.green-tint .metric-label { color: rgba(30,61,47,0.45); }
.metric-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 36px;
  font-weight: 400;
  color: var(--text);
  line-height: 1;
}
.metric-card.green-tint .metric-value { color: var(--forest); }
.metric-sub {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  margin-top: 8px;
}
.metric-card.green-tint .metric-sub { color: rgba(30,61,47,0.45); }
.progress-wrap { margin-top: 12px; }
.progress-bar-bg { height: 3px; background: var(--border); border-radius: 2px; }
.progress-bar-fill { height: 3px; border-radius: 2px; background: var(--forest); transition: width 0.6s ease; }
.metric-card.green-tint .progress-bar-bg { background: rgba(30,61,47,0.1); }
.progress-label { display: flex; justify-content: space-between; margin-top: 5px; }
.progress-label span { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--text-faint); }
.fico-link {
  display: block; text-decoration: none;
  border: 0.5px solid rgba(30,61,47,0.15);
  background: var(--forest-lighter);
}
.fico-link:hover { border-color: var(--forest); background: #e4efea; }
.fico-link-row {
  display: flex; align-items: center; justify-content: space-between; margin-top: 10px;
}
.fico-link-label { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--forest); letter-spacing: 0.06em; }
.fico-arrow { font-size: 14px; color: var(--forest); opacity: 0.6; }
.refi-strip {
  background: var(--forest-lighter);
  border: 0.5px solid rgba(30,61,47,0.1);
  border-radius: var(--radius-lg);
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 1rem;
}
.refi-strip-left { display: flex; align-items: center; gap: 10px; }
.refi-strip-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--forest); opacity: 0.4; }
.refi-strip-text { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--forest); letter-spacing: 0.06em; }
.refi-strip-hint { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text-faint); }

/* ‚îÄ‚îÄ Expansion Slot ‚îÄ‚îÄ */
.expansion-slot {
  background: var(--surface);
  border: 0.5px dashed var(--border);
  border-radius: var(--radius-lg);
  padding: 2rem 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 1rem;
}
.expansion-slot span:first-child {
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  color: var(--text-faint);
}
.expansion-slot span:last-child {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  opacity: 0.6;
}

/* ‚îÄ‚îÄ State Messages ‚îÄ‚îÄ */
.state-msg {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--text-faint);
  padding: 1.25rem 0;
  text-align: center;
  letter-spacing: 0.04em;
}
.error-msg {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--red);
  padding: 0.5rem 0;
}

/* ‚îÄ‚îÄ Overlays ‚îÄ‚îÄ */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,24,0.4);
  display: none;
  align-items: center; justify-content: center;
  z-index: 100;
}
.overlay.open { display: flex; }
.panel {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 2rem;
  width: 400px;
  border: 0.5px solid var(--border);
  box-shadow: 0 8px 40px rgba(0,0,0,0.08);
}
.panel h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 400;
  color: var(--forest);
  margin-bottom: 0.5rem;
  letter-spacing: 0.04em;
}
.panel-subtitle {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  margin-bottom: 1.5rem;
  letter-spacing: 0.04em;
}
.field { margin-bottom: 1rem; }
.field label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: block;
  margin-bottom: 5px;
}
.field input, .field select {
  width: 100%;
  padding: 9px 12px;
  border: 0.5px solid var(--border);
  border-radius: var(--radius);
  font-family: 'DM Mono', monospace;
  font-size: 12px;
  color: var(--text);
  background: var(--bg);
  outline: none;
  transition: border-color 0.2s;
}
.field input:focus { border-color: var(--forest); background: #fff; }
.panel-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 1.5rem; }
.btn-cancel {
  background: transparent; border: 0.5px solid var(--border);
  color: var(--text-muted); font-family: 'DM Sans', sans-serif;
  font-size: 13px; padding: 8px 18px; border-radius: var(--radius); cursor: pointer;
}
.btn-save {
  background: var(--forest); border: none; color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px; padding: 8px 18px; border-radius: var(--radius); cursor: pointer;
}
.panel-hint {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--green);
  text-align: center;
  margin-top: 10px;
  letter-spacing: 0.04em;
}
.first-run-msg {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--amber);
  background: var(--amber-bg);
  padding: 8px 12px;
  border-radius: var(--radius);
  margin-bottom: 1rem;
  text-align: center;
  border: 0.5px solid rgba(183,98,26,0.2);
}

/* ‚îÄ‚îÄ Connectors ‚îÄ‚îÄ */
.connectors {
  display: flex;
  gap: 12px;
  margin-bottom: 2rem;
}
.connector {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text-faint);
  padding: 4px 10px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  letter-spacing: 0.04em;
}
.connector-dot {
  width: 5px; height: 5px; border-radius: 50%;
}
.connector-dot.ok { background: var(--green); }
.connector-dot.off { background: var(--text-faint); }
.connector-dot.err { background: var(--red); }

/* ‚îÄ‚îÄ Responsive ‚îÄ‚îÄ */
@media (max-width: 780px) {
  body { padding: 1.5rem 1rem 3rem; }
  .header { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .header-right { flex-wrap: wrap; }
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .email-grid { grid-template-columns: 1fr; }
  .metrics-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .stats-row { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- ‚îÄ‚îÄ Settings Overlay ‚îÄ‚îÄ -->
<div class="overlay" id="settingsOverlay">
  <div class="panel">
    <h3>Settings</h3>
    <div class="panel-subtitle">API keys are stored in your browser only</div>
    <div id="firstRunMsg" class="first-run-msg" style="display:none">enter your credentials to get started</div>

    <div class="field">
      <label>Supabase Project URL</label>
      <input type="text" id="inp-sb-url" placeholder="https://abc123.supabase.co">
    </div>
    <div class="field">
      <label>Supabase Anon Key</label>
      <input type="password" id="inp-sb-key" placeholder="eyJ...">
    </div>
    <div class="field">
      <label>Anthropic API Key</label>
      <input type="password" id="inp-anthropic" placeholder="sk-ant-...">
    </div>
    <div class="field">
      <label>Todoist Token</label>
      <input type="password" id="inp-todoist" placeholder="paste token here">
    </div>

    <div class="panel-actions">
      <button class="btn-cancel" onclick="closeSettings()">Cancel</button>
      <button class="btn-save" onclick="saveSettings()">Save</button>
    </div>
    <p class="panel-hint">&#128274; stored in your browser only</p>
  </div>
</div>

<!-- ‚îÄ‚îÄ Edit Rentals Overlay ‚îÄ‚îÄ -->
<div class="overlay" id="editOverlay">
  <div class="panel">
    <h3>Update Rentals</h3>
    <div class="field">
      <label>Rent collected this month ($)</label>
      <input type="number" id="inp-rent" placeholder="e.g. 5800">
    </div>
    <div class="field">
      <label>Rent expected this month ($)</label>
      <input type="number" id="inp-expected" placeholder="e.g. 6500">
    </div>
    <div class="field">
      <label>Portfolio cash flow this month ($)</label>
      <input type="number" id="inp-cashflow" placeholder="e.g. 420">
    </div>
    <div class="field">
      <label>Total revolving debt ($)</label>
      <input type="number" id="inp-debt" placeholder="e.g. 22080">
    </div>
    <div class="field">
      <label>Current mortgage FICO median</label>
      <input type="number" id="inp-fico" placeholder="e.g. 659">
    </div>
    <div class="panel-actions">
      <button class="btn-cancel" onclick="closeEdit()">Cancel</button>
      <button class="btn-save" onclick="saveMetrics()">Save</button>
    </div>
    <p class="panel-hint">saves to your browser automatically</p>
  </div>
</div>

<!-- ‚îÄ‚îÄ Header ‚îÄ‚îÄ -->
<div class="header">
  <div class="header-left">
    <div class="brand">
      <h1>Blackburn</h1>
      <p>Personal dashboard</p>
    </div>
    <div class="divider-v"></div>
    <div class="date-block">
      <div class="day" id="dayDisplay"></div>
      <div class="full-date" id="dateDisplay"></div>
    </div>
  </div>
  <div class="header-right">
    <div class="live-badge"><div class="live-dot"></div>live</div>
    <button class="icon-btn" onclick="openSettings()">&#9881; settings</button>
    <button class="icon-btn" onclick="App.refreshAll()">&#8635; refresh</button>
  </div>
</div>

<!-- ‚îÄ‚îÄ Connectors ‚îÄ‚îÄ -->
<div class="connectors">
  <div class="connector"><div class="connector-dot off" id="dot-supabase"></div>supabase</div>
  <div class="connector"><div class="connector-dot off" id="dot-todoist"></div>todoist</div>
  <div class="connector"><div class="connector-dot off" id="dot-claude"></div>claude</div>
</div>

<!-- ‚îÄ‚îÄ Quick Stats ‚îÄ‚îÄ -->
<div class="stats-row">
  <div class="stat-card">
    <div class="stat-label">Unread Emails</div>
    <div class="stat-value" id="stat-emails">‚Äî</div>
    <div class="stat-sub" id="stat-emails-sub">connect supabase</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Action Needed</div>
    <div class="stat-value" id="stat-action">‚Äî</div>
    <div class="stat-sub" id="stat-action-sub">from inbox</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Open Tasks</div>
    <div class="stat-value" id="stat-tasks">‚Äî</div>
    <div class="stat-sub" id="stat-tasks-sub">connect todoist</div>
  </div>
  <div class="stat-card accent">
    <div class="stat-label">FICO Median</div>
    <div class="stat-value" id="stat-fico">‚Äî</div>
    <div class="stat-sub" id="stat-fico-sub">target: 700</div>
  </div>
</div>

<!-- ‚îÄ‚îÄ Emails ‚îÄ‚îÄ -->
<div class="section">
  <div class="section-header">
    <span class="section-title">Inbox</span>
    <div class="section-meta">
      <span class="section-ts" id="ts-emails"></span>
      <span class="section-count" id="count-emails">‚Äî</span>
    </div>
  </div>
  <div id="emailList" class="email-grid">
    <div class="state-msg" style="grid-column:1/-1">connect supabase in settings to see emails</div>
