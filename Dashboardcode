<script>
/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Config ‚Äî all keys from localStorage
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
const Config = {
  get SUPABASE_URL()  { return localStorage.getItem('cfg-sb-url') || ''; },
  get SUPABASE_KEY()  { return localStorage.getItem('cfg-sb-key') || ''; },
  get ANTHROPIC_KEY() { return localStorage.getItem('cfg-anthropic-key') || ''; },
  get TODOIST_TOKEN() { return localStorage.getItem('cfg-todoist-token') || ''; },
  REFRESH_MS: 5 * 60 * 1000,
  CLAUDE_MODEL: 'claude-sonnet-4-20250514',
  MAX_EMAILS: 20,
};

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Helpers
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmt(n) { return n > 0 ? '$' + n.toLocaleString() : '‚Äî'; }
function timeStr() { return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }); }
function setTs(id) { document.getElementById(id).textContent = 'updated ' + timeStr(); }
function setDot(id, state) { document.getElementById(id).className = 'connector-dot ' + state; }

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Supabase ‚Äî lightweight REST client
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
const Supabase = {
  headers() {
    return {
      'apikey': Config.SUPABASE_KEY,
      'Authorization': 'Bearer ' + Config.SUPABASE_KEY,
      'Content-Type': 'application/json',
    };
  },

  async fetchEmails(limit) {
    limit = limit || Config.MAX_EMAILS;
    const url = Config.SUPABASE_URL + '/rest/v1/emails?order=received_at.desc&limit=' + limit;
    const res = await fetch(url, { headers: this.headers() });
    if (!res.ok) throw new Error('Supabase ' + res.status);
    return res.json();
  },

  async updateSummary(id, summaryJson) {
    const url = Config.SUPABASE_URL + '/rest/v1/emails?id=eq.' + id;
    await fetch(url, {
      method: 'PATCH',
      headers: Object.assign(this.headers(), { 'Prefer': 'return=minimal' }),
      body: JSON.stringify({ summary: summaryJson }),
    });
  },
};

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Claude Summarizer
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
const Summarizer = {
  async summarizeBatch(emails) {
    const unsummarized = emails.filter(function(e) { return !e.summary; });
    if (!unsummarized.length || !Config.ANTHROPIC_KEY) return;

    var emailBlock = unsummarized.map(function(e, i) {
      return '[' + (i+1) + '] From: ' + e.from_name + '\nSubject: ' + e.subject + '\nBody: ' + (e.snippet || e.body_text || '(empty)');
    }).join('\n\n');

    try {
      var res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': Config.ANTHROPIC_KEY,
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-direct-browser-access': 'true',
        },
        body: JSON.stringify({
          model: Config.CLAUDE_MODEL,
          max_tokens: 1500,
          system: 'You summarize emails for a personal dashboard for Ethan Blackburn \u2014 W2 employee at The David Allen Company and owner of Blackburn Real Estate LLC (6 rental properties). Return a JSON array only, no markdown. Each object: "index" (1-based position in list), "summary" (one plain sentence), "tags" (array of zero or more of: "urgent", "action_needed", "mentions_you", "fyi").',
          messages: [{ role: 'user', content: emailBlock }],
        }),
      });
      var data = await res.json();
      var results = JSON.parse(data.content[0].text);
      setDot('dot-claude', 'ok');

      results.forEach(function(r) {
        var email = unsummarized[r.index - 1];
        if (!email) return;
        var summaryObj = { summary: r.summary, tags: r.tags };
        email.summary = summaryObj;
        Supabase.updateSummary(email.id, summaryObj);
      });

      renderEmails(emails);
    } catch(e) {
      console.error('Summarization failed:', e);
      setDot('dot-claude', 'err');
    }
  },
};

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Render ‚Äî Emails
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
function renderEmails(emails) {
  var el = document.getElementById('emailList');
  var countEl = document.getElementById('count-emails');

  if (!emails.length) {
    el.innerHTML = '<div class="state-msg" style="grid-column:1/-1">inbox zero &#10003;</div>';
    countEl.textContent = '0';
    return;
  }

  var actionCount = 0;
  var html = emails.map(function(e) {
    var s = e.summary || {};
    if (typeof s === 'string') { try { s = JSON.parse(s); } catch(x) { s = {}; } }
    var tags = s.tags || [];
    var isUrgent = tags.indexOf('urgent') !== -1;
    var isAction = tags.indexOf('action_needed') !== -1;
    if (isAction || isUrgent) actionCount++;

    var borderClass = isUrgent ? 'urgent' : isAction ? 'action' : 'fyi';
    var tagHtml = tags.map(function(t) {
      var cls = t === 'urgent' ? 'tag-urgent' : t === 'action_needed' ? 'tag-action' : t === 'mentions_you' ? 'tag-you' : 'tag-fyi';
      return '<span class="tag ' + cls + '">' + t.replace('_', ' ') + '</span>';
    }).join('');

    var summaryHtml = s.summary
      ? '<div class="email-summary">' + esc(s.summary) + '</div>'
      : '<div class="skeleton"></div><div class="skeleton"></div>';

    return '<div class="email-card ' + borderClass + '">' +
      '<div class="email-from">' + esc(e.from_name || 'Unknown') + '</div>' +
      '<div class="email-subject">' + esc(e.subject || '(no subject)') + '</div>' +
      summaryHtml +
      '<div class="email-tags">' + tagHtml + '</div>' +
    '</div>';
  }).join('');

  el.innerHTML = html;
  countEl.textContent = emails.length + ' emails';
  document.getElementById('stat-emails').textContent = emails.length;
  document.getElementById('stat-emails-sub').textContent = actionCount ? actionCount + ' need action' : 'all clear';
  document.getElementById('stat-action').textContent = actionCount || 0;
  document.getElementById('stat-action-sub').textContent = actionCount ? 'from inbox' : 'nothing urgent';
}

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Render ‚Äî Tasks
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
function renderTasks(tasks) {
  var el = document.getElementById('taskList');
  var countEl = document.getElementById('count-tasks');
  var today = new Date().toISOString().split('T')[0];
  var relevant = tasks.filter(function(t) {
    return !t.due ? t.priority >= 3 : t.due.date <= today;
  }).sort(function(a, b) { return b.priority - a.priority; }).slice(0, 12);

  countEl.textContent = relevant.length + ' open';
  document.getElementById('stat-tasks').textContent = relevant.length;
  document.getElementById('stat-tasks-sub').textContent = relevant.length ? relevant.length + ' due today' : 'all clear';

  if (!relevant.length) {
    el.innerHTML = '<div class="state-msg">all clear &#10003;</div>';
    return;
  }

  el.innerHTML = relevant.map(function(t) {
    var over = t.due && t.due.date < today;
    var due = t.due ? (over ? 'overdue \u00b7 ' + t.due.date : 'due ' + t.due.date) : 'no due date';
    return '<div class="task-item">' +
      '<div class="priority-dot p-' + t.priority + '"></div>' +
      '<div><div class="task-text">' + esc(t.content) + '</div>' +
      '<div class="task-meta' + (over ? ' overdue' : '') + '">' + due + '</div></div>' +
    '</div>';
  }).join('');
}

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Render ‚Äî Rentals (localStorage)
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
function loadMetrics() {
  var rent = parseFloat(localStorage.getItem('m-rent') || '0');
  var expected = parseFloat(localStorage.getItem('m-expected') || '0');
  var cashflow = parseFloat(localStorage.getItem('m-cashflow') || '0');
  var debt = parseFloat(localStorage.getItem('m-debt') || '0');
  var fico = parseFloat(localStorage.getItem('m-fico') || '0');
  var pct = function(a, b) { return b > 0 ? Math.min(100, Math.round(a / b * 100)) : 0; };

  document.getElementById('m-rent').textContent = fmt(rent);
  document.getElementById('m-rent-sub').textContent = expected > 0 ? 'of ' + fmt(expected) + ' expected' : 'of \u2014 expected';
  document.getElementById('m-rent-bar').style.width = pct(rent, expected) + '%';

  var cfEl = document.getElementById('m-cashflow');
  cfEl.textContent = cashflow !== 0 ? (cashflow >= 0 ? '+$' : '\u2212$') + Math.abs(cashflow).toLocaleString() : '\u2014';
  cfEl.style.color = cashflow < 0 ? 'var(--red)' : 'var(--forest)';

  document.getElementById('m-debt').textContent = fmt(debt);

  if (fico > 0) {
    var base = 580, target = 700;
    var progress = Math.max(0, Math.min(100, Math.round((fico - base) / (target - base) * 100)));
    document.getElementById('m-fico').textContent = fico;
    document.getElementById('stat-fico').textContent = fico;
    var pts = target - fico;
    var ficoMsg = fico >= target ? '\u2713 target reached' : pts + ' pts to go';
    document.getElementById('m-fico-sub').textContent = ficoMsg;
    document.getElementById('stat-fico-sub').textContent = fico >= target ? 'target reached' : pts + ' pts to 700';
    document.getElementById('m-fico-bar').style.width = progress + '%';
    document.getElementById('m-fico-lo').textContent = String(base);
  }
}

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Settings & Edit Overlays
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
function openSettings(firstRun) {
  document.getElementById('inp-sb-url').value = localStorage.getItem('cfg-sb-url') || '';
  document.getElementById('inp-sb-key').value = localStorage.getItem('cfg-sb-key') || '';
  document.getElementById('inp-anthropic').value = localStorage.getItem('cfg-anthropic-key') || '';
  document.getElementById('inp-todoist').value = localStorage.getItem('cfg-todoist-token') || '';
  document.getElementById('firstRunMsg').style.display = firstRun ? 'block' : 'none';
  document.getElementById('settingsOverlay').classList.add('open');
}
function closeSettings() { document.getElementById('settingsOverlay').classList.remove('open'); }
function saveSettings() {
  var fields = [
    ['inp-sb-url', 'cfg-sb-url'],
    ['inp-sb-key', 'cfg-sb-key'],
    ['inp-anthropic', 'cfg-anthropic-key'],
    ['inp-todoist', 'cfg-todoist-token'],
  ];
  fields.forEach(function(f) {
    var v = document.getElementById(f[0]).value.trim();
    if (v) localStorage.setItem(f[1], v);
  });
  closeSettings();
  App.refreshAll();
}
document.getElementById('settingsOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeSettings();
});

function openEdit() {
  ['rent','expected','cashflow','debt','fico'].forEach(function(k) {
    document.getElementById('inp-' + k).value = localStorage.getItem('m-' + k) || '';
  });
  document.getElementById('editOverlay').classList.add('open');
}
function closeEdit() { document.getElementById('editOverlay').classList.remove('open'); }
function saveMetrics() {
  ['rent','expected','cashflow','debt','fico'].forEach(function(k) {
    localStorage.setItem('m-' + k, document.getElementById('inp-' + k).value);
  });
  closeEdit();
  loadMetrics();
}
document.getElementById('editOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeEdit();
});

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   Date Display
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
function updateDate() {
  var now = new Date();
  var days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('dayDisplay').textContent = days[now.getDay()];
  document.getElementById('dateDisplay').textContent = months[now.getMonth()] + ' ' + now.getDate() + ', ' + now.getFullYear();
}

/* ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê
   App ‚Äî main controller
   ‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê */
const App = {
  async refreshEmails() {
    if (!Config.SUPABASE_URL || !Config.SUPABASE_KEY) {
      setDot('dot-supabase', 'off');
      return;
    }
    try {
      var emails = await Supabase.fetchEmails();
      setDot('dot-supabase', 'ok');
      renderEmails(emails);
      setTs('ts-emails');
      if (Config.ANTHROPIC_KEY) {
        setDot('dot-claude', 'ok');
        Summarizer.summarizeBatch(emails);
      }
    } catch(e) {
      setDot('dot-supabase', 'err');
      document.getElementById('emailList').innerHTML = '<div class="error-msg" style="grid-column:1/-1">couldn\'t load emails \u2014 check Supabase settings</div>';
    }
  },

  async refreshTasks() {
    if (!Config.TODOIST_TOKEN) {
      setDot('dot-todoist', 'off');
      return;
    }
    var el = document.getElementById('taskList');
    el.innerHTML = '<div class="state-msg">loading...</div>';
    try {
      var res = await fetch('https://api.todoist.com/rest/v2/tasks', {
        headers: { Authorization: 'Bearer ' + Config.TODOIST_TOKEN },
      });
      if (!res.ok) {
        var errText = await res.text();
        throw new Error(res.status + ': ' + errText);
      }
      var tasks = await res.json();
      setDot('dot-todoist', 'ok');
      renderTasks(tasks);
      setTs('ts-tasks');
    } catch(e) {
      setDot('dot-todoist', 'err');
      el.innerHTML = '<div class="error-msg">couldn\'t load tasks \u2014 ' + esc(e.message) + '</div>';
      document.getElementById('count-tasks').textContent = '\u2014';
    }
  },

  async refreshAll() {
    updateDate();
    loadMetrics();
    await Promise.allSettled([this.refreshEmails(), this.refreshTasks()]);
  },

  init() {
    updateDate();
    loadMetrics();
    this.refreshAll();
    setInterval(function() { App.refreshAll(); }, Config.REFRESH_MS);
    if (!Config.SUPABASE_URL && !Config.TODOIST_TOKEN) {
      setTimeout(function() { openSettings(true); }, 500);
    }
  },
};

App.init();
</script>
